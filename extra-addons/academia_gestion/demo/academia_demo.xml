<odoo>
    <data noupdate="1">
        <!-- Datos de demostración para Estudiantes -->
        <record id="estudiante_demo_1" model="academia.estudiante">
            <field name="name">Juan Pérez</field>
            <field name="fecha_nacimiento">2000-05-15</field>
            <field name="email">juan.perez@example.com</field>
            <field name="telefono">111-222-3333</field>
            <field name="direccion">Calle Falsa 123</field>
        </record>

        <record id="estudiante_demo_2" model="academia.estudiante">
            <field name="name">María García</field>
            <field name="fecha_nacimiento">2001-11-20</field>
            <field name="email">maria.garcia@example.com</field>
            <field name="telefono">444-555-6666</field>
            <field name="direccion">Avenida Siempre Viva 742</field>
        </record>

        <record id="estudiante_demo_3" model="academia.estudiante">
            <field name="name">Pedro López</field>
            <field name="fecha_nacimiento">2008-01-01</field>
            <field name="email">pedro.lopez@example.com</field>
            <field name="telefono">777-888-9999</field>
            <field name="direccion">Plaza Mayor 1</field>
        </record>

        <!-- Datos de demostración para Profesores -->
        <record id="profesor_demo_1" model="academia.profesor">
            <field name="name">Dr. Carlos Ruiz</field>
            <field name="email">carlos.ruiz@example.com</field>
            <field name="telefono">123-456-7890</field>
            <field name="especialidad">Matemáticas</field>
            <field name="estudiante_ids" eval="[(6,0,[ref("estudiante_demo_1"), ref("estudiante_demo_3")])]"/>
        </record>

        <record id="profesor_demo_2" model="academia.profesor">
            <field name="name">Lic. Ana Fernández</field>
            <field name="email">ana.fernandez@example.com</field>
            <field name="telefono">987-654-3210</field>
            <field name="especialidad">Literatura</field>
            <field name="estudiante_ids" eval="[(6,0,[ref("estudiante_demo_2")])]"/>
        </record>

        <record id="profesor_demo_3" model="academia.profesor">
            <field name="name">Ing. Laura Gómez</field>
            <field name="email">laura.gomez@example.com</field>
            <field name="telefono">555-123-4567</field>
            <field name="especialidad">Física</field>
        </record>

        <!-- Relacionar con res.partner (opcional, Odoo lo crea automáticamente si no existe) -->
        <record id="res_partner_estudiante_juan" model="res.partner">
            <field name="name">Juan Pérez</field>
            <field name="email">juan.perez@example.com</field>
            <field name="estudiante_id" eval="[(4, ref('estudiante_demo_1'))]"/>
        </record>

        <record id="res_partner_profesor_carlos" model="res.partner">
            <field name="name">Dr. Carlos Ruiz</field>
            <field name="email">carlos.ruiz@example.com</field>
            <field name="profesor_id" eval="[(4, ref('profesor_demo_1'))]"/>
        </record>

    </data>
</odoo>
