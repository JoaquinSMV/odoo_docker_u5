<odoo>
    <data>
        <template id="report_estudiante_document">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2>Informe de Estudiante: <span t-field="o.name"/></h2>
                            <p><strong>Email:</strong> <span t-field="o.email"/></p>
                            <p><strong>Teléfono:</strong> <span t-field="o.telefono"/></p>
                            <p><strong>Fecha de Nacimiento:</strong> <span t-field="o.fecha_nacimiento"/></p>
                            <p><strong>Edad:</strong> <span t-field="o.edad"/></p>
                            <p><strong>Dirección:</strong> <span t-field="o.direccion"/></p>

                            <h3>Profesores Asignados:</h3>
                            <ul>
                                <t t-if="o.profesor_ids">
                                    <li t-foreach="o.profesor_ids" t-as="profesor">
                                        <span t-field="profesor.name"/> (<span t-field="profesor.especialidad"/>)
                                    </li>
                                </t>
                                <t t-else="">
                                    <li>Ningún profesor asignado.</li>
                                </t>
                            </ul>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>
