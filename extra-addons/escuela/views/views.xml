      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "list,form",
          "res_model": model._name,
        }
      </field>
    </record>
-->

    <!-- Top menu item -->

    <menuitem name="escuela" id="escuela.menu_root"/>

    <!-- menu categories -->

    <menuitem name="Escuela" id="escuela.profesor_menu_1" parent="escuela.menu_root"/>

    <!-- actions -->

    <menuitem name="Profesores" id="escuela.profesor_menu_1_list" parent="escuela.profesor_menu_1"
              action="escuela.profesor_action_window"/>
    

  </data>
</odoo>
